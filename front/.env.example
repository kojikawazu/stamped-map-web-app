# Supabase（@nuxtjs/supabase が読む変数名）
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# MapTiler
NUXT_PUBLIC_MAPTILER_KEY=your-maptiler-key

# Site URL（OAuth リダイレクト先ベースURL）
# 本番: https://your-domain.vercel.app
# ローカル: 省略可（window.location.origin にフォールバック）
NUXT_PUBLIC_SITE_URL=

# Google OAuth（Supabase Auth Provider 設定で使用）
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
